@page "/consent-personal-data"
@model Agrojob.Pages.Docs.ConsentToTheProcessingOfPersonalDataModel
@{
    ViewData["Title"] = "Согласие на обработку персональных данных";
}

<div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <!-- Основная карточка документа -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4 p-md-5">
                    
                    <!-- Заголовок -->
                    <div class="mb-4 pb-1 border-bottom">
                        <h1 class="h2 fw-semibold mb-2">Согласие на обработку персональных данных</h1>
                        <p class="text-secondary-emphasis mb-1">информационного сервиса «агрокадры.рф»</p>
                    </div>

                    <!-- 1. Предмет согласия -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">1. Предмет согласия</h2>
                        <p class="mb-2">
                            Я, субъект персональных данных, регистрируясь на сайте https://агрокадры.рф и/или используя его функциональные возможности, действуя свободно, своей волей и в своем интересе, в соответствии со статьёй 9 Федерального закона от 27.07.2006 № 152-ФЗ «О персональных данных» выражаю согласие ОБЩЕСТВУ С ОГРАНИЧЕННОЙ ОТВЕТСТВЕННОСТЬЮ «ДАТАСПРИНТ» ОГРН 1253600017758, ИНН 3665833294 (далее - Оператор) на обработку моих персональных данных на следующих условиях.
                        </p>
                    </section>

                    <!-- 2. Перечень действий с персональными данными -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">2. Перечень действий с персональными данными</h2>
                        <p class="mb-2">
                            Оператор вправе осуществлять обработку моих персональных данных, включая их сбор, запись, систематизацию, накопление, хранение, уточнение (обновление, изменение), извлечение, использование, передачу (предоставление, доступ), обезличивание, блокирование, удаление и уничтожение как с использованием средств автоматизации, так и без их использования.
                        </p>
                    </section>

                    <!-- 3. Перечень обрабатываемых персональных данных -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">3. Перечень обрабатываемых персональных данных</h2>
                        <p class="mb-2">
                            Согласие предоставляется в отношении следующих персональных данных: фамилия, имя, отчество; адрес электронной почты; номер телефона; год, месяц, дата рождения; место проживания; фотографии; сведения об образовании, профессии, специальности и квалификации; сведения о трудовой деятельности и стаже работы; сведения о воинском учете (в случае их добровольного указания); а также иные данные, добровольно предоставленные мною при заполнении профиля, размещении резюме или вакансии. Также подлежат обработке технические данные, автоматически передаваемые при использовании Сайта, включая IP-адрес, сведения о браузере и устройстве, файлы cookie.
                        </p>
                    </section>

                    <!-- 4. Цели обработки персональных данных -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">4. Цели обработки персональных данных</h2>
                        <p class="mb-2">
                            Обработка персональных данных осуществляется в целях регистрации и идентификации пользователя на Сайте, предоставления доступа к сервисам Сайта, размещения резюме и вакансий, обеспечения взаимодействия между работодателями и соискателями, направления уведомлений, связанных с использованием Сайта, исполнения договорных обязательств, а также соблюдения требований законодательства Российской Федерации.
                        </p>
                    </section>

                    <!-- 5. Передача персональных данных третьим лицам -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">5. Передача персональных данных третьим лицам</h2>
                        <p class="mb-2">
                            Я согласен(на), что мои персональные данные могут быть предоставлены зарегистрированным пользователям Сайта (работодателям и соискателям) в рамках функционала сервиса, а также третьим лицам, привлекаемым Оператором для технического обеспечения работы Сайта, на основании заключённых договоров поручения обработки персональных данных. Передача персональных данных государственным органам осуществляется в случаях и порядке, предусмотренных законодательством Российской Федерации. Трансграничная передача персональных данных не осуществляется.
                        </p>
                    </section>

                    <!-- 6. Локализация и хранение персональных данных -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">6. Локализация и хранение персональных данных</h2>
                        <p class="mb-2">
                            Мне известно, что обработка и хранение персональных данных граждан Российской Федерации осуществляется с использованием баз данных, расположенных на территории Российской Федерации.
                        </p>
                    </section>

                    <!-- 7. Срок действия согласия и порядок его отзыва -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">7. Срок действия согласия и порядок его отзыва</h2>
                        <p class="mb-2">
                            Настоящее согласие действует с момента его предоставления и до достижения целей обработки персональных данных либо до момента его отзыва. Согласие может быть отозвано мною в любое время путём направления письменного уведомления на электронный адрес Оператора: <a href="mailto:datasprint@mail.ru" class="text-decoration-none">datasprint@mail.ru</a> с пометкой «Отзыв согласия на обработку персональных данных». В случае отзыва согласия Оператор вправе продолжить обработку персональных данных без моего согласия при наличии оснований, предусмотренных законодательством Российской Федерации.
                        </p>
                    </section>

                    <!-- 8. Подтверждение ознакомления с правами субъекта персональных данных -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">8. Подтверждение ознакомления с правами субъекта персональных данных</h2>
                        <p class="mb-2">
                            Подтверждаю, что мне разъяснены права субъекта персональных данных, предусмотренные законодательством Российской Федерации, в том числе право на получение информации, касающейся обработки моих персональных данных, право требовать их уточнения, блокирования или уничтожения, а также право на защиту своих прав и законных интересов.
                        </p>
                        <p class="mb-2">
                            Предоставляя настоящее согласие посредством проставления отметки на Сайте и совершения действия по регистрации (или иного подтверждающего действия), я подтверждаю, что ознакомлен(а) с Политикой в отношении обработки персональных данных и принимаю её условия.
                        </p>
                    </section>

                    <!-- Нижний колонтитул cshtml -->
                    <div class="small text-muted mt-4 pt-2 border-top text-end">
                        <span>Версия от 05.03.2026</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>