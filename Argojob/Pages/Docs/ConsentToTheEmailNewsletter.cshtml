@page "/consent-newsletter"
@model Agrojob.Pages.Docs.ConsentToTheEmailNewsletterModel
@{
    ViewData["Title"] = "Согласие на получение информационных и рекламных сообщений";
}

<div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <!-- Основная карточка документа -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4 p-md-5">
                    
                    <!-- Заголовок -->
                    <div class="mb-4 pb-1 border-bottom">
                        <h1 class="h2 fw-semibold mb-2">Согласие на получение информационных и рекламных сообщений</h1>
                        <p class="text-secondary-emphasis mb-1">информационного сервиса «агрокадры.рф»</p>
                    </div>

                    <!-- 1. Общие положения -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">1. Общие положения</h2>
                        <p class="mb-2">
                            Настоящим я, действуя свободно, своей волей и в своем интересе, в соответствии с Федеральным законом от 13.03.2006 № 38-ФЗ «О рекламе» и Федеральным законом от 27.07.2006 № 152-ФЗ «О персональных данных», выражаю согласие ОБЩЕСТВУ С ОГРАНИЧЕННОЙ ОТВЕТСТВЕННОСТЬЮ «ДАТАСПРИНТ», ОГРН 1253600017758, ИНН 3665833294 (далее — Оператор), на получение информационных и рекламных сообщений посредством электронной почты в рамках использования информационного сервиса «агрокадры.рф», размещённого по адресу https://агрокадры.рф (далее — Сайт).
                        </p>
                        <p class="mb-2 fw-medium bg-light p-3 rounded-3">
                            Настоящее согласие является самостоятельным и предоставляется отдельно от согласия на обработку персональных данных.
                        </p>
                    </section>

                    <!-- 2. Предмет согласия -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">2. Предмет согласия</h2>
                        <p class="mb-2">
                            Я даю согласие на направление в мой адрес электронных писем, содержащих информацию о вакансиях, резюме, откликах, обновлениях функционала Сайта, новостях сервиса, специальных предложениях, мероприятиях, а также иных информационных и рекламных материалах, связанных с деятельностью Сайта. Рассылка может осуществляться как автоматически, так и с участием сотрудников Оператора.
                        </p>
                    </section>

                    <!-- 3. Перечень обрабатываемых данных -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">3. Перечень обрабатываемых данных</h2>
                        <p class="mb-2">
                            В целях осуществления рассылки Оператор вправе обрабатывать следующие персональные данные: адрес электронной почты, фамилию, имя, отчество, а также сведения о пользовательской активности на Сайте, необходимые для персонализации сообщений.
                        </p>
                        <p class="mb-2">
                            Обработка осуществляется в соответствии с Политикой в отношении обработки персональных данных, размещённой на Сайте.
                        </p>
                    </section>

                    <!-- 4. Способ предоставления согласия -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">4. Способ предоставления согласия</h2>
                        <p class="mb-2">
                            Согласие предоставляется путем проставления отметки (галочки) в соответствующем поле при регистрации на Сайте либо при подписке на рассылку, либо путем совершения иного подтверждающего действия, явно свидетельствующего о намерении получать информационные и рекламные сообщения. Отсутствие отметки означает отказ от получения рекламной рассылки.
                        </p>
                    </section>

                    <!-- 5. Срок действия согласия и порядок его отзыва -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">5. Срок действия согласия и порядок его отзыва</h2>
                        <p class="mb-2">
                            Настоящее согласие действует с момента его предоставления и до момента его отзыва. Я вправе в любое время отказаться от получения рассылки путем перехода по ссылке «Отписаться», размещенной в каждом электронном письме, либо путем направления уведомления на электронный адрес Оператора: <a href="mailto:datasprint@mail.ru" class="text-decoration-none">datasprint@mail.ru</a> с пометкой «Отказ от рассылки». После получения уведомления об отказе Оператор прекращает направление рекламных сообщений в разумный срок, но не позднее сроков, установленных законодательством Российской Федерации.
                        </p>
                    </section>

                    <!-- 6. Заключительные положения -->
                    <section class="mb-4">
                        <h2 class="h5 fw-bold mb-3">6. Заключительные положения</h2>
                        <p class="mb-2">
                            Предоставляя настоящее согласие, я подтверждаю, что указанный мною адрес электронной почты принадлежит мне и используется мною на законных основаниях.
                        </p>
                        <p class="mb-2">
                            Я уведомлен(а), что в случае отсутствия согласия на получение рекламных сообщений использование основного функционала Сайта не ограничивается.
                        </p>
                        <p class="mb-2">
                            Настоящее согласие может быть изменено Оператором в части организационных аспектов рассылки при сохранении прав Пользователя на отказ от её получения.
                        </p>
                    </section>

                    <!-- Нижний колонтитул cshtml -->
                    <div class="small text-muted mt-4 pt-2 border-top text-end">
                        <span>Версия от 05.03.2026</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>